<?php
/*
 * Backups – optional top-navigation quick link to the Vault web UI (#162).
 *
 * Rendered as its own top-nav entry (Menu="Tasks", Type="xmenu" – the same
 * supported extension point Community Applications uses for its "Apps"
 * button) and gated by the NAV_LINK key in vault.cfg via the Cond header, so
 * it only appears when the user enables "Show in top navigation" on
 * Settings → Utilities → Vault. Disabled by default. No core Unraid files
 * are patched.
 *
 * The embedded SPA runs in unraid-proxy mode (polling): a handful of
 * WebSocket-only live events (anomalies, live logs, replication sync) do not
 * stream here — matching the existing proxy-mode behaviour of the Utilities
 * page, not a regression of this entry.
 */
require_once '/usr/local/emhttp/plugins/vault/include/api.php';

$health  = vault_get('/health');
$running = !empty($health) && ($health['status'] ?? '') === 'ok';
$proxy_url = '/plugins/vault/include/app.php#/';
?>

<?php if (!$running): ?>
<div style="padding: 24px;">
    <h2><i class="fa fa-shield"></i> Vault</h2>
    <p>The Vault daemon is not running. Start it from
       <a href="/Settings/Vault">Settings &rarr; Utilities &rarr; Vault</a>.</p>
</div>
<?php else: ?>
<iframe id="vault-backups-frame"
        src="<?= htmlspecialchars($proxy_url, ENT_QUOTES, 'UTF-8') ?>"
        style="width: 100%; border: 0; display: block;"
        title="Vault Backups"></iframe>
<script>
(function() {
    var frame = document.getElementById('vault-backups-frame');
    if (!frame) return;

    // Size the frame to the viewport space below the Unraid header/nav so the
    // embedded app is usable without double scrollbars.
    function size() {
        var top = frame.getBoundingClientRect().top + window.pageYOffset;
        var h = Math.max(480, window.innerHeight - top - 24);
        frame.style.height = h + 'px';
    }
    size();
    window.addEventListener('resize', size);

    // app.php injects Unraid's csrf_token once per render and the SPA has no
    // in-app token refresh. A tab left open across a token rotation would have
    // its write actions (run job, delete, settings) fail silently — reload the
    // frame when the tab regains visibility so a fresh token is injected.
    var hiddenSince = 0;
    document.addEventListener('visibilitychange', function() {
        if (document.hidden) {
            hiddenSince = Date.now();
            return;
        }
        // Only bother for meaningful absences (> 10 minutes hidden).
        if (hiddenSince && (Date.now() - hiddenSince) > 10 * 60 * 1000) {
            frame.src = frame.src; // eslint-disable-line no-self-assign
        }
        hiddenSince = 0;
    });
})();
</script>
<?php endif; ?>
