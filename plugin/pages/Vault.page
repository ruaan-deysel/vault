<?php
require_once '/usr/local/emhttp/plugins/vault/include/api.php';

$plugin  = 'vault';
$cfg     = vault_load_config();
$port    = $cfg['PORT'] ?? '24085';

// Check if daemon is actually running via health endpoint.
$health  = vault_get('/health');
$running = !empty($health) && ($health['status'] ?? '') === 'ok';
$version = $health['version'] ?? '';

// Build endpoint URLs with correct IPv6 handling.
$raw_addr = $_SERVER['SERVER_ADDR'];
$addr_esc = htmlspecialchars(
    (strpos($raw_addr, ':') !== false) ? "[$raw_addr]" : $raw_addr,
    ENT_QUOTES, 'UTF-8'
);
$port_esc = htmlspecialchars($port, ENT_QUOTES, 'UTF-8');
?>

