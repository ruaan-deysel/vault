    <div id="vault-webui" style="display: <?= $running ? 'block' : 'none' ?>;">
        <a href="<?= htmlspecialchars($proxy_url, ENT_QUOTES, 'UTF-8') ?>" target="_blank"
           class="vault-webui-link" title="Open Vault Web Interface">
            <i class="fa fa-external-link" style="font-size:12px"></i>
            Open Vault Web UI
        </a>
    </div>

    <div style="margin-top: 10px;">
        <?php if ($running): ?>
            <input type="button" id="vault-btn-startstop" value="Stop" onclick="serviceControl('stop')">
            <input type="button" id="vault-btn-restart" value="Restart" onclick="serviceControl('restart')">
        <?php else: ?>
            <input type="button" id="vault-btn-startstop" value="Start" onclick="serviceControl('start')">
            <input type="button" id="vault-btn-restart" value="Restart" onclick="serviceControl('restart')" disabled>
        <?php endif; ?>
    </div>
</div>

<div class="title"><span class="left"><i class="title fa fa-wrench"></i>Configuration</span></div>

<form id="vaultConfigForm" method="POST" action="/update.php" target="progressFrame">
<input type="hidden" name="#file" value="<?=$plugin?>/vault.cfg">
<input type="hidden" name="#command" value="/plugins/<?=$plugin?>/include/apply.sh">

