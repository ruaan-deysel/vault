    <strong>Status:</strong>
    <i id="vault-status-orb" class="fa fa-circle <?= $running ? 'green-orb' : 'grey-orb' ?>"></i>
    <span id="vault-status-text" class="vault-status-text <?= $running ? 'running' : 'stopped' ?>">
        <?= $running ? 'RUNNING' : 'STOPPED' ?>
    </span>
    <span id="vault-version" style="margin-left: 6px; font-size: 0.85em; color: var(--gray-500, #888); display: <?= ($running && $version) ? 'inline' : 'none' ?>;"><?php if ($version): ?>v<?= htmlspecialchars($version) ?><?php endif; ?></span>

    <div id="vault-endpoints" class="vault-endpoints" style="display: <?= $running ? 'block' : 'none' ?>;">
        <p><strong>API Endpoint:</strong> http://<?= $addr_esc ?>:<?= $port_esc ?>/api/v1</p>
        <p><strong>WebSocket:</strong> ws://<?= $addr_esc ?>:<?= $port_esc ?>/api/v1/ws</p>
    </div>

    <div id="vault-webui" style="display: <?= $running ? 'block' : 'none' ?>;">
        <a href="http://<?= $addr_esc ?>:<?= $port_esc ?>/" target="_blank"
           class="vault-webui-link" title="Open Vault Web Interface">
            <i class="fa fa-external-link" style="font-size:12px"></i>
            Open Web UI
        </a>
    </div>

    <div style="margin-top: 10px;">
        <?php if ($running): ?>
            <input type="button" id="vault-btn-startstop" value="Stop" onclick="serviceControl('stop')">
            <input type="button" id="vault-btn-restart" value="Restart" onclick="serviceControl('restart')">
        <?php else: ?>
            <input type="button" id="vault-btn-startstop" value="Start" onclick="serviceControl('start')">
            <input type="button" id="vault-btn-restart" value="Restart" onclick="serviceControl('restart')" disabled>
        <?php endif; ?>
    </div>
</div>

