<script>
function resetDefaults() {
    if (!confirm('Reset Vault configuration to defaults?')) return;
    var xhr = new XMLHttpRequest();
    xhr.open('POST', '/plugins/vault/include/control.php', true);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.onreadystatechange = function() {
        if (xhr.readyState === 4) {
            if (xhr.status === 200) {
                location.reload();
            } else {
                alert('Failed to reset configuration. Please try again.');
            }
        }
    };
    xhr.send('action=reset-config&csrf_token=' + encodeURIComponent(<?=json_encode($var['csrf_token'] ?? '')?>));
}

function toggleNavLink(cb) {
    var status = document.getElementById('vault-navlink-status');
    var enabled = cb.checked ? 'yes' : 'no';
    cb.disabled = true;
    var xhr = new XMLHttpRequest();
    xhr.open('POST', '/plugins/vault/include/control.php', true);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.onreadystatechange = function() {
        if (xhr.readyState !== 4) return;
        cb.disabled = false;
        var ok = false;
        if (xhr.status === 200) {
            try { ok = !!JSON.parse(xhr.responseText).success; } catch (e) { /* fallthrough */ }
        }
        if (!ok) {
            cb.checked = !cb.checked; // revert
            if (status) {
                status.textContent = 'Failed to update the navigation setting.';
                status.style.display = 'block';
            }
            return;
        }
        if (status) {
            status.textContent = enabled === 'yes'
                ? 'Enabled — reloading to show the Backups entry…'
                : 'Disabled — reloading to remove the Backups entry…';
            status.style.display = 'block';
        }
        setTimeout(function() { location.reload(); }, 800);
    };
    xhr.send('action=navlink&enabled=' + enabled + '&csrf_token=' + encodeURIComponent(<?=json_encode($var['csrf_token'] ?? '')?>));
}

function serviceControl(action) {
    var btn = document.getElementById('vault-btn-startstop');
    var restartBtn = document.getElementById('vault-btn-restart');
    var orb = document.getElementById('vault-status-orb');
    var statusText = document.getElementById('vault-status-text');
    var webui = document.getElementById('vault-webui');
    var version = document.getElementById('vault-version');
    var errorEl = document.getElementById('vault-control-error');

    // Capture pre-action state so we can preserve it on failure rather than
    // pretending the action succeeded (issue #71).
    var wasRunning = statusText && statusText.classList.contains('running');

    function showError(msg) {
        if (!errorEl) return;
        errorEl.textContent = msg;
        errorEl.style.display = 'block';
    }
    function clearError() {
        if (!errorEl) return;
        errorEl.textContent = '';
        errorEl.style.display = 'none';
    }
    function applyRunningState(running) {
        if (running) {
            orb.className = 'fa fa-circle green-orb';
            statusText.textContent = 'RUNNING';
            statusText.className = 'vault-status-text running';
            webui.style.display = 'block';
            if (version) version.style.display = 'inline';
            btn.value = 'Stop';
            btn.onclick = function() { serviceControl('stop'); };
            if (restartBtn) restartBtn.disabled = false;
        } else {
            orb.className = 'fa fa-circle grey-orb';
            statusText.textContent = 'STOPPED';
            statusText.className = 'vault-status-text stopped';
            webui.style.display = 'none';
            if (version) version.style.display = 'none';
            btn.value = 'Start';
            btn.onclick = function() { serviceControl('start'); };
            if (restartBtn) restartBtn.disabled = true;
        }
    }
    function pollStatus() {
        // Re-query the daemon a moment later to confirm the action's real
        // outcome – the immediate response can race the daemon shutdown/start.
        var poll = new XMLHttpRequest();
        poll.open('POST', '/plugins/vault/include/control.php', true);
        poll.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
        poll.onreadystatechange = function() {
            if (poll.readyState !== 4) return;
            if (poll.status === 200) {
                try {
                    var d = JSON.parse(poll.responseText);
                    if (typeof d.running === 'boolean') applyRunningState(d.running);
                } catch(e) { /* keep current state */ }
            }
            btn.disabled = false;
            if (restartBtn) restartBtn.disabled = !(statusText && statusText.classList.contains('running'));
        };
        poll.send('action=status&csrf_token=' + encodeURIComponent(<?=json_encode($var['csrf_token'] ?? '')?>));
    }

    clearError();
    btn.disabled = true;
    if (restartBtn) restartBtn.disabled = true;

    var xhr = new XMLHttpRequest();
    xhr.open('POST', '/plugins/vault/include/control.php', true);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.onreadystatechange = function() {
        if (xhr.readyState !== 4) return;

        // Conservative on failure: keep the pre-action state and surface an
        // error rather than mis-reporting STOPPED when the daemon is still
        // running (issue #71).
        if (xhr.status !== 200) {
            applyRunningState(wasRunning);
            showError('Vault service control failed (HTTP ' + xhr.status + '). The daemon state is unchanged.');
            btn.disabled = false;
            if (restartBtn) restartBtn.disabled = !wasRunning;
            return;
        }

        var data = null;
        try {
            data = JSON.parse(xhr.responseText);
        } catch(e) {
            applyRunningState(wasRunning);
            showError('Unexpected response from Vault service control.');
            btn.disabled = false;
            if (restartBtn) restartBtn.disabled = !wasRunning;
            return;
        }

        if (data && data.success === false) {
            showError(data.error || 'Vault service control reported a failure.');
        }

        if (data && typeof data.running === 'boolean') {
            applyRunningState(data.running);
        }

        // Confirm with a follow-up status query (~1.2s) – this is the
        // ground-truth check used by the page-load path (/api/v1/health).
        setTimeout(pollStatus, 1200);
    };
    xhr.send('action=' + action + '&csrf_token=' + encodeURIComponent(<?=json_encode($var['csrf_token'] ?? '')?>));
}

// After applying a config change (port / bind address), apply.sh restarts the
// daemon. The form posts into a hidden iframe, so the submission itself shows
// nothing – the submit handler shows a transient inline note and this function
// polls the daemon's real status, clearing the note and surfacing a clear error
// if it failed to come back up, e.g. the chosen port is already in use
// (issue #124).
function pollAfterApply(attempts) {
    // ~12 polls × 3s ≈ 36s. A restart that takes the hybrid DB-restore path can
    // need ~15-20s to bind and serve health; a shorter window would report a
    // false STOPPED until the user refreshes (issues #124, #139).
    if (attempts === undefined) attempts = 12;

    var orb = document.getElementById('vault-status-orb');
    var statusText = document.getElementById('vault-status-text');
    var webui = document.getElementById('vault-webui');
    var version = document.getElementById('vault-version');
    var errorEl = document.getElementById('vault-control-error');
    var startStop = document.getElementById('vault-btn-startstop');
    var restartBtn = document.getElementById('vault-btn-restart');
    var applyStatus = document.getElementById('vault-apply-status');

    function render(running) {
        // The apply finished – the orb/error now carry the outcome, so the
        // transient "Restarting…" note is no longer needed.
        if (applyStatus) applyStatus.style.display = 'none';
        if (orb) orb.className = 'fa fa-circle ' + (running ? 'green-orb' : 'grey-orb');
        if (statusText) {
            statusText.textContent = running ? 'RUNNING' : 'STOPPED';
            statusText.className = 'vault-status-text ' + (running ? 'running' : 'stopped');
        }
        if (webui) webui.style.display = running ? 'block' : 'none';
        if (version && !running) version.style.display = 'none';
        if (startStop) {
            startStop.value = running ? 'Stop' : 'Start';
            startStop.onclick = (function(r) { return function() { serviceControl(r ? 'stop' : 'start'); }; })(running);
        }
        if (restartBtn) restartBtn.disabled = !running;
        if (errorEl) {
            if (running) {
                errorEl.textContent = '';
                errorEl.style.display = 'none';
            } else {
                errorEl.textContent = 'Vault daemon is not running after applying the configuration. The chosen port may be invalid or already in use – check the Vault log, then revert the port or pick another.';
                errorEl.style.display = 'block';
            }
        }
    }

    var poll = new XMLHttpRequest();
    poll.open('POST', '/plugins/vault/include/control.php', true);
    poll.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    poll.onreadystatechange = function() {
        if (poll.readyState !== 4) return;
        var running = false;
        if (poll.status === 200) {
            try { running = !!JSON.parse(poll.responseText).running; } catch(e) { /* treat as down */ }
        }
        // The restart (graceful stop + start) can take a few seconds; only
        // conclude the daemon is down after exhausting the retry budget.
        if (running) {
            render(true);
        } else if (attempts > 1) {
            setTimeout(function() { pollAfterApply(attempts - 1); }, 3000);
        } else {
            render(false);
        }
    };
    poll.send('action=status&csrf_token=' + encodeURIComponent(<?=json_encode($var['csrf_token'] ?? '')?>));
}

(function() {
    var form = document.getElementById('vaultConfigForm');
    if (!form) return;
    form.addEventListener('submit', function() {
        // Unraid reloads this page when the #apply form is submitted, which
        // wipes any feedback shown now. Stash the intent in sessionStorage so
        // the reloaded page can surface the result inline (handled below),
        // co-located with the form instead of as raw script output above the
        // footer. apply.sh only restarts the daemon when it was already
        // running, so record that to decide whether to poll for a restart.
        var statusText = document.getElementById('vault-status-text');
        var wasRunning = !!(statusText && statusText.classList.contains('running'));
        try {
            sessionStorage.setItem('vaultApply', JSON.stringify({ t: Date.now(), wasRunning: wasRunning }));
        } catch (e) { /* sessionStorage unavailable – skip inline feedback */ }
    });
})();

// On the reload that follows an Apply, surface the outcome inline next to the
// form rather than as Unraid's raw progress output near the footer.
(function() {
    var raw;
    try { raw = sessionStorage.getItem('vaultApply'); } catch (e) { return; }
    if (!raw) return;
    try { sessionStorage.removeItem('vaultApply'); } catch (e) { /* ignore */ }

    var info;
    try { info = JSON.parse(raw); } catch (e) { return; }
    if (!info || (Date.now() - info.t) > 30000) return; // stale – ignore

    var applyStatus = document.getElementById('vault-apply-status');
    if (info.wasRunning) {
        if (applyStatus) {
            applyStatus.textContent = '↻ Applying configuration – restarting daemon…';
            applyStatus.style.display = 'block';
        }
        // apply.sh restarted the daemon; confirm it came back up. This clears
        // the note on success or shows a clear error if it failed (issue #124).
        pollAfterApply(12);
    } else if (applyStatus) {
        // Daemon was stopped, so apply.sh only saved the config – nothing to
        // poll for.
        applyStatus.textContent = 'Configuration saved.';
        applyStatus.style.display = 'block';
        setTimeout(function() { applyStatus.style.display = 'none'; }, 4000);
    }
})();
</script>
