</blockquote>
<?php endif; ?>

<dl>
    <dt><input type="submit" name="#default" value="Default"></dt>
    <dd><input type="submit" name="#apply" value="Apply" disabled><input type="button" value="Done" onclick="done()"></dd>
</dl>
</form>

<script>
function serviceControl(action) {
    var btn = document.getElementById('vault-btn-startstop');
    var restartBtn = document.getElementById('vault-btn-restart');
    var orb = document.getElementById('vault-status-orb');
    var statusText = document.getElementById('vault-status-text');
    var webui = document.getElementById('vault-webui');
    var version = document.getElementById('vault-version');

    btn.disabled = true;
    if (restartBtn) restartBtn.disabled = true;

    var xhr = new XMLHttpRequest();
    xhr.open('POST', '/plugins/vault/include/control.php', true);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.onreadystatechange = function() {
        if (xhr.readyState !== 4) return;
        btn.disabled = false;

        var running = false;
        if (xhr.status === 200) {
            try {
                var data = JSON.parse(xhr.responseText);
                running = data.running;
            } catch(e) {
                running = (action === 'start' || action === 'restart');
            }
        } else {
            running = (action === 'start' || action === 'restart');
        }

        if (running) {
            orb.className = 'fa fa-circle green-orb';
            statusText.textContent = 'RUNNING';
            statusText.className = 'vault-status-text running';
            webui.style.display = 'block';
            if (version) version.style.display = 'inline';
            btn.value = 'Stop';
            btn.onclick = function() { serviceControl('stop'); };
            if (restartBtn) restartBtn.disabled = false;
        } else {
            orb.className = 'fa fa-circle grey-orb';
            statusText.textContent = 'STOPPED';
            statusText.className = 'vault-status-text stopped';
            webui.style.display = 'none';
            if (version) version.style.display = 'none';
            btn.value = 'Start';
            btn.onclick = function() { serviceControl('start'); };
            if (restartBtn) restartBtn.disabled = true;
        }
    };
    xhr.send('action=' + action + '&csrf_token=<?=$var["csrf_token"]?>');
}
</script>
