?>

<link rel="stylesheet" href="/plugins/vault/assets/css/vault.css">

<div class="vault-page">
    <div class="vault-header">
        <h1>Backup Jobs</h1>
        <button class="vault-btn vault-btn-primary" onclick="showCreateJobModal()">Create Job</button>
    </div>

    <table class="vault-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Schedule</th>
                <th>Type Chain</th>
                <th>Storage</th>
                <th>Enabled</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <?php foreach ($jobs as $job): ?>
            <tr>
                <td><?= htmlspecialchars($job['name']) ?></td>
                <td><?= htmlspecialchars($job['schedule'] ?: 'Manual') ?></td>
                <td><?= htmlspecialchars($job['backup_type_chain']) ?></td>
                <td><?= $job['storage_dest_id'] ?></td>
                <td><?= $job['enabled'] ? 'Yes' : 'No' ?></td>
                <td>
                    <button class="vault-btn vault-btn-sm" onclick="runJob(<?= $job['id'] ?>)">Run Now</button>
                    <button class="vault-btn vault-btn-sm" onclick="editJob(<?= $job['id'] ?>)">Edit</button>
                    <button class="vault-btn vault-btn-sm vault-btn-danger" onclick="deleteJob(<?= $job['id'] ?>)">Delete</button>
                </td>
            </tr>
            <?php endforeach; ?>
        </tbody>
    </table>
</div>

<!-- Create Job Modal -->
<div id="createJobModal" class="vault-modal" style="display:none;">
    <div class="vault-modal-content">
        <h2>Create Backup Job</h2>
        <form id="createJobForm">
            <div class="vault-form-group">
                <label>Job Name</label>
                <input type="text" name="name" required>
            </div>
            <div class="vault-form-group">
                <label>Description</label>
                <input type="text" name="description">
            </div>
            <div class="vault-form-group">
                <label>Schedule (cron)</label>
                <input type="text" name="schedule" placeholder="0 2 * * *">
                <small>Leave empty for manual-only</small>
            </div>
            <div class="vault-form-group">
                <label>Backup Type Chain</label>
                <select name="backup_type_chain">
                    <option value="full">Full Only</option>
                    <option value="full,incremental">Full + Incremental</option>
                    <option value="full,incremental,differential">Full + Incremental + Differential</option>
                </select>
            </div>
            <div class="vault-form-group">
                <label>Compression</label>
                <select name="compression">
                    <option value="zstd">Zstandard (recommended)</option>
                    <option value="gzip">Gzip</option>
                    <option value="none">None</option>
                </select>
            </div>
            <div class="vault-form-group">
                <label>Storage Destination</label>
                <select name="storage_dest_id">
                    <?php foreach ($storage as $dest): ?>
                    <option value="<?= $dest['id'] ?>"><?= htmlspecialchars($dest['name']) ?> (<?= $dest['type'] ?>)</option>
                    <?php endforeach; ?>
                </select>
            </div>
            <div class="vault-form-group">
                <label>Retention - Keep</label>
                <input type="number" name="retention_count" value="7" min="1"> restore points
            </div>
            <div class="vault-form-group">
                <label>Retention - Delete after</label>
                <input type="number" name="retention_days" value="30" min="1"> days
            </div>
            <div class="vault-form-actions">
                <button type="button" class="vault-btn" onclick="hideModal('createJobModal')">Cancel</button>
                <button type="submit" class="vault-btn vault-btn-primary">Create</button>
            </div>
        </form>
    </div>
</div>

<script src="/plugins/vault/assets/js/vault.js"></script>
