Title="Storage"
Tabs="true"
Icon="shield"
Markdown="false"
---
<?php
require_once '/usr/local/emhttp/plugins/vault/include/api.php';
$destinations = vault_get('/storage') ?: [];
?>

<link rel="stylesheet" href="/plugins/vault/assets/css/vault.css">

<div class="vault-page">
    <div class="vault-header">
        <h1>Storage Destinations</h1>
        <button class="vault-btn vault-btn-primary" onclick="showCreateStorageModal()">Add Destination</button>
    </div>

    <table class="vault-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Type</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <?php foreach ($destinations as $dest): ?>
            <tr>
                <td><?= htmlspecialchars($dest['name']) ?></td>
                <td><?= strtoupper($dest['type']) ?></td>
                <td><span id="storage-status-<?= $dest['id'] ?>">-</span></td>
                <td>
                    <button class="vault-btn vault-btn-sm" onclick="testStorage(<?= $dest['id'] ?>)">Test</button>
                    <button class="vault-btn vault-btn-sm" onclick="editStorage(<?= $dest['id'] ?>)">Edit</button>
                    <button class="vault-btn vault-btn-sm vault-btn-danger" onclick="deleteStorage(<?= $dest['id'] ?>)">Delete</button>
                </td>
            </tr>
            <?php endforeach; ?>
        </tbody>
    </table>
</div>

<!-- Add Storage Modal -->
<div id="createStorageModal" class="vault-modal" style="display:none;">
    <div class="vault-modal-content">
        <h2>Add Storage Destination</h2>
        <form id="createStorageForm">
            <div class="vault-form-group">
                <label>Name</label>
                <input type="text" name="name" required>
            </div>
            <div class="vault-form-group">
                <label>Type</label>
                <select name="type" onchange="showStorageConfig(this.value)">
                    <option value="local">Local Path</option>
                    <option value="smb">SMB Share</option>
                    <option value="sftp">SFTP/SSH</option>
                    <option value="nfs">NFS</option>
                </select>
            </div>
            <div id="storageConfigFields">
                <!-- Dynamic fields based on type -->
            </div>
            <div class="vault-form-actions">
                <button type="button" class="vault-btn" onclick="hideModal('createStorageModal')">Cancel</button>
                <button type="submit" class="vault-btn vault-btn-primary">Add</button>
            </div>
        </form>
    </div>
</div>

<script src="/plugins/vault/assets/js/vault.js"></script>
