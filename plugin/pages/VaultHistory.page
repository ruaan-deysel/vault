Title="History"
Tabs="true"
Icon="shield"
Markdown="false"
---
<?php
require_once '/usr/local/emhttp/plugins/vault/include/api.php';
$jobs = vault_get('/jobs') ?: [];
?>

<link rel="stylesheet" href="/plugins/vault/assets/css/vault.css">

<div class="vault-page">
    <h1>Backup History</h1>

    <div class="vault-form-group">
        <label>Filter by Job</label>
        <select id="historyJobFilter" onchange="loadHistory(this.value)">
            <option value="all">All Jobs</option>
            <?php foreach ($jobs as $job): ?>
            <option value="<?= $job['id'] ?>"><?= htmlspecialchars($job['name']) ?></option>
            <?php endforeach; ?>
        </select>
    </div>

    <table class="vault-table">
        <thead>
            <tr>
                <th>Job</th>
                <th>Status</th>
                <th>Type</th>
                <th>Items</th>
                <th>Size</th>
                <th>Started</th>
                <th>Completed</th>
            </tr>
        </thead>
        <tbody id="historyBody">
            <?php foreach ($jobs as $job):
                $runs = vault_get('/jobs/' . $job['id'] . '/history?limit=10');
                if ($runs): foreach ($runs as $run): ?>
            <tr>
                <td><?= htmlspecialchars($job['name']) ?></td>
                <td><span class="vault-badge badge-<?= $run['status'] ?>"><?= $run['status'] ?></span></td>
                <td><?= $run['backup_type'] ?></td>
                <td><?= $run['items_done'] ?>/<?= $run['items_total'] ?> (<?= $run['items_failed'] ?> failed)</td>
                <td><?= number_format($run['size_bytes'] / 1024 / 1024, 1) ?> MB</td>
                <td><?= $run['started_at'] ?></td>
                <td><?= $run['completed_at'] ?></td>
            </tr>
            <?php endforeach; endif; endforeach; ?>
        </tbody>
    </table>
</div>

<script src="/plugins/vault/assets/js/vault.js"></script>
