Title="Settings"
Tabs="true"
Icon="shield"
Markdown="false"
---
<?php
require_once '/usr/local/emhttp/plugins/vault/include/api.php';
$health = vault_get('/health');
?>

<link rel="stylesheet" href="/plugins/vault/assets/css/vault.css">

<div class="vault-page">
    <h1>Vault Settings</h1>

    <div class="vault-card">
        <h3>Daemon Status</h3>
        <p>Status: <strong><?= ($health['status'] ?? 'offline') ?></strong></p>
        <p>Version: <strong><?= ($health['version'] ?? 'unknown') ?></strong></p>
        <p>API Port: <strong><?= vault_get_port() ?></strong></p>
    </div>

    <h2>Default Settings</h2>
    <form id="settingsForm">
        <div class="vault-form-group">
            <label>Default Compression</label>
            <select name="default_compression">
                <option value="zstd">Zstandard</option>
                <option value="gzip">Gzip</option>
                <option value="none">None</option>
            </select>
        </div>
        <div class="vault-form-group">
            <label>Notification Level</label>
            <select name="notify_on">
                <option value="failure">Failures only</option>
                <option value="warning">Warnings and failures</option>
                <option value="always">Always</option>
            </select>
        </div>
        <div class="vault-form-actions">
            <button type="submit" class="vault-btn vault-btn-primary">Save Settings</button>
        </div>
    </form>
</div>

<script src="/plugins/vault/assets/js/vault.js"></script>
